{
  "name": "dure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js --no-skills",
    "chat": "tsx --env-file=.env src/main.ts chat",
    "equity": "tsx --env-file=.env src/main.ts equity",
    "screen": "tsx --env-file=.env src/main.ts screen",
    "strategy": "tsx --env-file=.env src/main.ts strategy",
    "backtest": "tsx --env-file=.env src/main.ts backtest",
    "scenario": "tsx --env-file=.env src/main.ts scenario",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
